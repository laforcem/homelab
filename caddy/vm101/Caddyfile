{
    email {$EMAIL}
}

*.{$DOMAIN} {
    tls {
        dns porkbun {
            api_key {$API_KEY}
            api_secret_key {$SECRET_KEY}
        }
    }
    
    @plex host plex.{$DOMAIN}
    handle @plex {
        reverse_proxy plex:32400 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host plex.{$DOMAIN}
        }
    }
    
    @immich host photos.{$DOMAIN}
    handle @immich {
        reverse_proxy immich_server:2283
    }

    @karakeep host bookmarks.{$DOMAIN}
    handle @karakeep {
        reverse_proxy karakeep:3000
    }

    @invidious host invidious.{$DOMAIN}
    handle @invidious {
        # Only allow access from VLAN 10
        @not_vlan10 not remote_ip 192.168.10.0/24
        handle @not_vlan10 {
            abort
        }

        @cors_preflight {
            method OPTIONS
        }
        respond @cors_preflight 204

        header Access-Control-Allow-Credentials true
        header Access-Control-Allow-Origin "https://youtube.{$DOMAIN}" {
            defer
        }
        header Access-Control-Allow-Methods "GET,POST,OPTIONS,HEAD,PATCH,PUT,DELETE"
        header Access-Control-Allow-Headers "User-Agent,Authorization,Content-Type"

        reverse_proxy invidious:3000
    }

    @materialious host youtube.{$DOMAIN}
    handle @materialious {
        # Only allow access from VLAN 10
        @not_vlan10 not remote_ip 192.168.10.0/24
        handle @not_vlan10 {
            abort
        }

        reverse_proxy materialious:80
    }

    @invidious-companion host invidious-companion.{$DOMAIN}
    handle @invidious-companion {
        # Only allow access from VLAN 10
        @not_vlan10 not remote_ip 192.168.10.0/24
        handle @not_vlan10 {
            abort
        }

        @cors_preflight {
            method OPTIONS
        }
        respond @cors_preflight 204

        header Access-Control-Allow-Credentials true
        @allowed_origin header_regexp origin Origin ^https://(invidious|youtube)\.{$DOMAIN}$
        handle @allowed_origin {
            header Access-Control-Allow-Origin "{http.request.header.Origin}" {
                defer
            }
        }
        header Access-Control-Allow-Methods "GET, POST, OPTIONS, HEAD, PATCH, PUT, DELETE"
        header Access-Control-Allow-Headers "User-Agent, Authorization, Content-Type"

        # Rewrite /api/* requests to /companion/api/*
        @api_requests path /api/*
        rewrite @api_requests /companion{uri}

        reverse_proxy invidious-companion:8282
    }
    
    handle {
        abort
    }    
}
