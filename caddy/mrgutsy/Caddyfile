{
    email {$EMAIL}
}

*.{$DOMAIN} {
    tls {
        dns porkbun {
            api_key {$API_KEY}
            api_secret_key {$SECRET_KEY}
        }
    }
    
    @actual host budget.{$DOMAIN}
    handle @actual {
        reverse_proxy actual:5006
    }
    
    @audiobookshelf host audiobooks.{$DOMAIN}
    handle @audiobookshelf {
        reverse_proxy audiobookshelf:80
    }
    
    @miniflux host miniflux.{$DOMAIN}
    handle @miniflux {
        reverse_proxy miniflux:8080
    }
    
    @recipes host recipes.{$DOMAIN}
    handle @recipes {
        reverse_proxy tandoor-web:80
    }
    
    handle {
        abort
    }    
}
