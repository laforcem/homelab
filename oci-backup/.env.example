# OCI authentication — get these from OCI console: Profile → API Keys
OCI_CLI_USER=ocid1.user.oc1..example
OCI_CLI_FINGERPRINT=aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99
OCI_CLI_TENANCY=ocid1.tenancy.oc1..example
OCI_CLI_REGION=us-ashburn-1
# Paste full PEM key content inline, including -----BEGIN/END----- lines
OCI_CLI_KEY_CONTENT=

# Boot volume OCID — get from OCI console: Compute → Boot Volumes
BOOT_VOLUME_ID=ocid1.bootvolume.oc1.iad.example

# Backup display name prefix. Backups will be named <prefix>-YYYY-MM-DD_HH-MM-SS
BACKUP_NAME_PREFIX=mrgutsy-boot

# Cron schedule for automated backups (default: 3am daily)
BACKUP_INTERVAL_CRON=0 3 * * *
