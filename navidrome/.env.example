LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_SECRET=your_lastfm_secret_here
DOMAIN=example.com
AUDIOMUSEAI_PLUGIN_VERSION=v8

# AudioMuse-AI core service (the analysis/recommendation backend the plugin talks to)
AUDIOMUSE_POSTGRES_USER=audiomuse
AUDIOMUSE_POSTGRES_PASSWORD=change_me

# Dedicated Navidrome service account AudioMuse-AI uses to read your library
AUDIOMUSE_NAVIDROME_USER=audiomuse
AUDIOMUSE_NAVIDROME_PASSWORD=change_me

# AudioMuse-AI's own admin login (for its web UI)
AUDIOMUSE_ADMIN_USER=admin
AUDIOMUSE_ADMIN_PASSWORD=change_me
AUDIOMUSE_JWT_SECRET=change_me_to_a_random_secret

# Bearer token the Navidrome plugin uses for server-to-server API calls (AUTH_ENABLED requires this)
AUDIOMUSE_API_TOKEN=change_me_to_a_random_token
