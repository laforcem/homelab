# =============================================================================
# FIRST-RUN SETUP
# =============================================================================
# On first startup, the TeamSpeak server generates a one-time admin privilege
# key and prints it to the container logs. You must claim it in the TS3 client
# to gain server admin rights. This is a one-time step — once claimed, the key
# is consumed and your TS3 identity is permanently bound to the admin role.
#
# After running `docker compose up -d`, retrieve the key with:
#
#   docker compose logs teamspeak | grep "token="
#
# The first person to connect will be prompted to use this key.
# =============================================================================

# Server display name shown in the TS3 client
TS3_SERVER_NAME=My TeamSpeak Server

# Password required to join the server
TS3_SERVER_PASSWORD=changeme

# Maximum concurrent users (free license max: 32)
TS3_SLOTS=10

# Message shown to users on connect (optional, leave blank to disable)
TS3_WELCOME_MESSAGE=
